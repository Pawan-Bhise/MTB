@model List<PMEHCRM.Models.Login>
@{
    ViewBag.Title = "User List";
}
<div class="content-box">
    <div class=" p-4">
        <div class="d-flex">
            <div class="m-2">
                <a class=" btn btn-primary" asp-controller="Admin" asp-action="Index"> Back To Dashboard </a>
            </div>
            <div class="m-2">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus"></i> Create New User
                </a>
            </div>
        </div>
        <h2>User List</h2>
        <div class="table-scroll-wrapper tatable-responsive">
            <table class="data-table table-bordered table table-hover text-center tablet desktop display nowrap" id="user-rcords" width="100%">
                <thead>
                    <tr>
                        <th class="bg-black text-white text-center">Username</th>
                        <th class="bg-black text-white text-center">Role</th>
                        <th class="bg-black text-white text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Username</td>
                            <td>@user.Role</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-primary mx-2">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@user.UserId" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-danger delete-confirm mx-2">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="modal fade text-black" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content p-4">
                        <div class="modal-header">
                            <h5 class="modal-title" id="confirmDeleteLabel">Confirm Delete</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure, you want to delete this user?
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="col-md-6 m-1">
                                <button type="button" class="btn btn-dark text-white w-100" data-bs-dismiss="modal">No</button>
                            </div>
                            <div class="col-md-6 m-1">
                                <button type="button" class="btn btn-danger w-100" id="confirmDeleteBtn">Yes</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    // View Tciket Records jQuery:
    $(document).ready(function () {
        if ($('#user-rcords tbody tr').length > 0) {
            $('#user-rcords').DataTable({
                "pageLength": 10,
                "order": [],
                responsive: true,
                fixedHeader: true,
                columnDefs: [
                    { responsivePriority: 1, targets: 0 },
                    { responsivePriority: 2, targets: -1 }
                ],
                "scrollX": true,
                responsive: {
                    breakpoints: [
                        { name: 'desktop', width: Infinity },
                        { name: 'tablet', width: 1024 },
                        { name: 'fablet', width: 768 },
                        { name: 'phone', width: 480 }
                    ]
                }
            });
        } else {
            console.log("No data found. Table not initialized.");
        }
    });

    $(function() {
        
        let formToSubmit = null;
        const confirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));

        $('.delete-confirm').click(function(e) {
            e.preventDefault();
            formToSubmit = $(this).closest('form'); // store the form
            confirmModal.show();
        });

        $('#confirmDeleteBtn').click(function() {
            if (formToSubmit) {
                formToSubmit.submit(); // submit form when Yes clicked
            }
        });
    });
</script>