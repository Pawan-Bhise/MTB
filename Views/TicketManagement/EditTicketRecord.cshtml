@model PMEHCRM.Models.TicketManagement

@{
    ViewData["Title"] = "EditTicketRecord";
}

<div class="content-box">
    <div class=" p-4">
        @if (Context.Session.GetString("Role") == "Admin")
        {
            <div class="my-4 ">
                <a class="btn-primary text-decoration-none border-3  rounded p-2 text-white" asp-controller="TicketManagement" asp-action="ViewTicketRecords"> Back To Ticket Records </a>
            </div>
        }
        else if (Context.Session.GetString("Role") == "Supervisor")
        {
            <div class="my-4">
                <a class="btn-primary text-decoration-none border-3 rounded p-2 text-white" asp-controller="TicketManagement" asp-action="ViewTicketRecords"> Back To Ticket Records  </a>
            </div>
        }
        else if (Context.Session.GetString("Role") == "User")
        {
            <div class="my-4">
                <a class="btn-primary text-decoration-none border-3 rounded p-2 text-white" asp-controller="TicketManagement" asp-action="ViewTicketRecords"> Back To Ticket Records  </a>
            </div>
        }
        <form asp-controller="TicketManagement" asp-action="EditTicketRecord" method="post" enctype="multipart/form-data" class="ticket-mgmt p-4 border-3 rounded">
            <!--  Anti Forgery Token to ensure a valid post! -->
            @Html.AntiForgeryToken()

            <div class="form-headings bg-primary text-white text-center m-2 p-1 rounded">
                <h4 class="">Ticket Management Form</h4>
            </div>
            <!-- Calling Details -->
            <h4 class="text-dark mb-3">Calling Details</h4>
            <div class="row justify-content-center align-items-center">
                <div class="form-group col-md-6 p-2">
                    <label asp-for="Name">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter name" />
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="CallingNumber">Calling Number</label>
                    <input asp-for="CallingNumber" class="form-control" placeholder="Enter calling number" />
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="TypeOfCaller">Type of Caller</label>
                    <select asp-for="TypeOfCaller" id="typeOfCaller" class="form-control" data-selected="@Model.TypeOfCaller">
                    </select>
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="CustomerSegment">Customer Segment</label>
                    <select asp-for="CustomerSegment" id="customerSegment" class="form-control" data-selected="@Model.CustomerSegment"></select>
                </div>
            </div>

            <!-- Type of Call and Categories -->
            <h4 class="mb-3">Type of Call and Categories</h4>
            <div class="row justify-content-center align-items-center">
                <div class="form-group col-md-6 p-2">
                    <label asp-for="TypeOfCall">Type of Call </label>
                    <select asp-for="TypeOfCall" id="typeOfCall" class="form-control" data-selected="@Model.TypeOfCall"></select>
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="Category">Category</label>
                    <select asp-for="Category" id="category" class="form-control" data-selected="@Model.Category"></select>
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="SubCategory">Sub Category</label>
                    <select asp-for="SubCategory" id="subCategory" class="form-control" data-selected="@Model.SubCategory"></select>
                </div>

                <div class="form-group col-md-6 p-2">
                    <label asp-for="SubSubCategory">Sub-Sub Category</label>
                    <select asp-for="SubSubCategory" id="subSubCategory" class="form-control" data-selected="@Model.SubSubCategory"></select>
                </div>
            </div>

            <!-- Radio Options -->
            <div class="form-group row p-2">
                <label>Select Option</label>
                <div class="form-check mx-2 col">
                    <input class="form-check-input" asp-for="SrOrTicket" type="radio" id="openSrOption"
                           value="Open SR" />
                    <label class="form-check-label">Open SR</label>
                </div>

                <div class="form-check mx-2 col">
                    <input class="form-check-input" asp-for="SrOrTicket" type="radio" id="raiseTicketOption"
                           value="Raise Ticket" />
                    <label class="form-check-label">Raise Ticket</label>
                </div>
                <div class="col-md-2"></div>
            </div>

            <!-- Customer Info -->
            <div id="customerInfoSection" style="display: none;">
                <h4 class="mb-3 form-headings ">Customer Information</h4>
                <div class="row justify-content-center align-items-center">
                    <div class="form-group col-md-6">
                        <label asp-for="CustomerName">Customer Name</label>
                        <input asp-for="CustomerName" id="customerName" placeholder="Enter customer name" class="form-control" />
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="PhoneNo">Phone No</label>
                        <input asp-for="PhoneNo" id="phoneNo" placeholder="Enter phone number" class="form-control" />
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" id="email" placeholder="Enter email" class="form-control" />
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="AgentName">Agent Name</label>
                        <input asp-for="AgentName" id="agentName" class="form-control" value="@ViewBag.AgentName" readonly />
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="RequestDetails">Request Details</label>
                        <textarea asp-for="RequestDetails" id="requestDetails" placeholder="Enter request or complaint details" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="Remarks">Remarks</label>
                        <textarea asp-for="Remarks" class="form-control" id="remarks" placeholder="Enter remarks" rows="4"></textarea>
                    </div>
                </div>
            </div>

            <!-- Ticket Info Section -->
            <div id="ticketManagementSection" style="display: none;">
                <div class="row justify-content-center align-items-center">
                    <div class="form-group p-2 col-md-6">
                        <label asp-for="TicketNumber">Ticket Number</label>
                        <input asp-for="TicketNumber" id="ticketNumber" placeholder="Auto-generated" class="form-control" readonly />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="LevelOfConflict">Level Of Conflict</label>
                        <select asp-for="LevelOfConflict" id="levelOfConflict" class="form-control">
                            <option>High</option>
                            <option>Medium</option>
                            <option>Low</option>
                        </select>
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="TicketStatus"> Ticket Status</label>
                        <select asp-for="TicketStatus" id="ticketStatus" class="form-control">
                            <option>Open</option>
                            <option>Reopen</option>
                            <option>Pending</option>
                            <option>Waiting for Customer</option>
                            <option>Escalate</option>
                            <option>Resolve</option>
                            <option>Close</option>
                        </select>
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="CreatedDateTime"> Created Date and Time</label>
                        <input asp-for="CreatedDateTime" id="createdDateTime" class="form-control" readonly value="@(DateTime.Now)" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="EscalatedDateTime">Escalated Date and Time</label>
                        <input asp-for="EscalatedDateTime" type="datetime-local" id="escalatedDateTime" class="form-control" readonly value="@(DateTime.Now)" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="ResolvedDateTime">Resolved Date and Time</label>
                        <input asp-for="ResolvedDateTime" type="datetime-local" id="resolvedDateTime" class="form-control" readonly value="@(DateTime.Now)" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="ClosedDateTime">Close Date and Time</label>
                        <input asp-for="ClosedDateTime" type="datetime-local" id="closeDateTime" class="form-control" readonly value="@(DateTime.Now)" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="ServiceLevel">Service Level</label>
                        <select asp-for="ServiceLevel" id="serviceLevel" class="form-control">
                            <option>Level-1 (Call Center)</option>
                            <option>Level-2 (Operations Team)</option>
                            <option>Level-2 (KYC Team)</option>
                            <option>Level-3 (Digital Finance)</option>
                        </select>
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="Assignee">Assignee</label>
                        <input asp-for="Assignee" type="text" id="assignee" class="form-control" placeholder="Enter assignee" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="ReAssignee">Re-Assignee</label>
                        <input asp-for="ReAssignee" type="text" id="reAssignee" class="form-control" placeholder="Enter re-assignee" />
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="Resolver">Resolver</label>
                        <select asp-for="Resolver" id="resolver" class="form-control" asp-items="@ViewBag.UserList">
                        </select>
                    </div>

                    <div class="form-group p-2 col-md-6">
                        <label asp-for="SLAStatus">SLA Status</label>
                        <input asp-for="SLAStatus" type="text" id="slaStatus" class="form-control" placeholder="Exceeded SLA or Within SLA"
                               readonly />
                    </div>
                </div>
            </div>


            <!-- Channel -->
            <div class="row justify-content-center align-items-center p-2">
                <div class="form-group col-md-6">
                    <label asp-for="Channel">Channel</label>
                    <select asp-for="Channel" id="channel" class="form-control">
                        <option>Call Center</option>
                        <option>Mail</option>
                        <option>Viber</option>
                        <option>Facebook Messenger</option>
                        <option>Website</option>
                        <option>Phone</option>
                    </select>
                </div>

                <!-- Edit Attachments -->
                <div class="form-group col-md-6">
                    <span class="text-danger">Note: Please upload the file again, if page reloads! </span>
                    <label asp-for="Attachments">Attach New Photos/Videos and Overwrite Existing Files</label>
                    <input asp-for="Attachments" type="file" class="form-control" multiple />
                    <span asp-validation-for="Attachments" class="text-danger"></span>
                    <span class="form-text text-danger">Upload and overwrite existing images/videos (Max 10 MB each)</span>
                    <span id="preview"></span>
                    <!-- Show existing attachments -->
                    @if (Model.Attachments != null && Model.Attachments.Any())
                    {
                        <div class="fw-bold">Existing Attachments:</div>
                        <div class="d-flex flex-wrap justify-content-center align-items-center">
                            @foreach (var file in Model.Attachments)
                            {
                                // Get File name that user uploaded
                                var nameWithoutExt = System.IO.Path.GetFileNameWithoutExtension(file.FileName);
                                var parts = nameWithoutExt.Split('-');
                                var displayName = parts[0];
                                var extension = System.IO.Path.GetExtension(file.FileName);

                                // Diplaying user's file name
                                <a href="@file.FilePath" class="btn btn-primary m-2" target="_blank">
                                    @($"{displayName}{extension}")
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No attachments uploaded yet.</p>
                    }
                </div>


                <div class="form-group p-2 col-md-12">
                    <label for="NewComment">Add Comment</label>
                    <textarea asp-for="Comment" class="form-control" row="3" placeholder="Write your comment here..."></textarea>
                </div>
            </div>

            <button type="submit" asp-route="@Model.Id" class="btn btn-primary btn-block edit-confirm">Save</button>
            <div class="modal fade" id="confirmEditModal" tabindex="-1" aria-labelledby="confirmEditLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content p-4">
                        <div class="modal-header ">
                            <h5 class="modal-title" id="confirmEditLabel">Confirm Edit</h5>
                            <button type="button" class="btn-close" aria-label="Close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure, you want to edit this record?
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="col-md-6 m-1">
                                <button type="button" class="btn btn-dark text-white w-100" data-bs-dismiss="modal">No</button>
                            </div>
                            <div class="col-md-6 m-1">
                                <button type="button" class="btn btn-danger w-100" id="confirmEditBtn">Yes</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<script>

    // jQuery to handle file size validation and preview
    $(document).ready(function () {
        if ($('#openSrOption').is(':checked')) {
            $('#customerInfoSection').show();
            $('#ticketManagementSection').hide();
        }
        else if ($('#raiseTicketOption').is(':checked')) {
            $('#customerInfoSection').hide();
            $('#ticketManagementSection').show();
        }
        $("input[name='Attachments']").on("change", function () {
            let $preview = $("#preview");
            $preview.empty();
            const maxFileSize = 10 * 1024 * 1024; // 10 MB max size
            $.each(this.files, function (i, file) {
                const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
                let $span = $("<span>").text(`${file.name} (${sizeInMB} MB)`);
                $preview.append($span);

                if (file.size > maxFileSize) {
                    alert(`${file.name} exceeds 10 MB limit.`);
                    $("input[name='Attachments']").val(""); // clear file input
                    $preview.empty(); // clear preview too
                    return false;
                }
            });
        });
    });

