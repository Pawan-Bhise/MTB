    // Populate dropdowns
    function populateDropdown(id, options) {
        const select = document.getElementById(id);
        select.innerHTML = '';
        const selectedValue = select.dataset.selected;

        options.forEach(option => {
            const opt = document.createElement('option');
            opt.value = option;
            opt.textContent = option;
            // select.appendChild(opt);
            // Auto-select if it matches the model value
            if (option === selectedValue) {
                opt.selected = true;
            }
            select.appendChild(opt);
        });

    }

        // Initial population
    populateDropdown('typeOfCaller', typeOfCallerOptions);
    populateDropdown('customerSegment', customerSegmentOptions);
    populateDropdown('typeOfCall', Object.keys(categoryOptions));

    // Update category based on TypeOfCall
    const typeOfCallSelect = document.getElementById('typeOfCall');
    typeOfCallSelect.addEventListener('change', function () {
        const categories = categoryOptions[this.value] || [];
        populateDropdown('category', categories);

        // Trigger category change to populate subCategory
        document.getElementById('category').dispatchEvent(new Event('change'));
    });

    // Update subCategory based on category
    document.getElementById('category').addEventListener('change', function () {
        const subCategories = subCategoryOptions[this.value] || [];
        populateDropdown('subCategory', subCategories);

        document.getElementById('subCategory').dispatchEvent(new Event('change'));
    });

    // Update subSubCategory based on subCategory
    document.getElementById('subCategory').addEventListener('change', function () {
        const subSubCategories = subSubCategoryOptions[this.value] || [];
        populateDropdown('subSubCategory', subSubCategories);
    });

    // Trigger initial population of dependent dropdowns
    typeOfCallSelect.dispatchEvent(new Event('change'));




    // Populate initial dropdowns
    document.getElementById('typeOfCall').dispatchEvent(new Event('change'));

    // Show/Hide sections based on selection (Open SR or Raise Ticket)
    document.getElementById('openSrOption').addEventListener('change', function () {
        if (this.checked) {
            document.getElementById('customerInfoSection').style.display = 'block';
            document.getElementById('ticketManagementSection').style.display = 'none';

            //Clear Raise Ticket fields when SR is selected
            document.querySelectorAll('#ticketManagementSection input, #ticketManagementSection select, #ticketManagementSection textarea')
                .forEach(el => el.value = '');
        }
    });

    document.getElementById('raiseTicketOption').addEventListener('change', function () {
        if (this.checked) {
            document.getElementById('customerInfoSection').style.display = 'none';
            document.getElementById('ticketManagementSection').style.display = 'block';

            //Clear SR fields when Raise Ticket is selected
            document.querySelectorAll('#customerInfoSection input, #customerInfoSection select, #customerInfoSection textarea')
                .forEach(el => el.value = '');
        }
    });

    $(function() {
        let formToSubmit = null;
        const confirmModal = new bootstrap.Modal(document.getElementById('confirmEditModal'));

        $('.edit-confirm').click(function(e) {
            e.preventDefault();
            formToSubmit = $(this).closest('form'); // store the form
            confirmModal.show();
        });
        $('#confirmEditBtn').click(function() {
            if (formToSubmit) {
                formToSubmit.submit(); // submit form when Yes clicked
            }
        });
    });
</script>