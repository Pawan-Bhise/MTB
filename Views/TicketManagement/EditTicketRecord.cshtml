    function getSubCategoryOptionsFor(selectedCategory) {
        const callerEl = document.getElementById('typeOfCaller');
        const segmentEl = document.getElementById('customerSegment');
        const caller = callerEl ? callerEl.value : '';
        const segment = segmentEl ? segmentEl.value : '';
        const key = `${caller}|${segment}|${selectedCategory}`;
        if (scenarioSubCategoryOverrides[key]) return scenarioSubCategoryOverrides[key];
        return subCategoryOptions[selectedCategory] || [];
    }

