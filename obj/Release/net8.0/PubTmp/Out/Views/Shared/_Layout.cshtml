@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"] - MTB Pay Ticketing System</title>

    @* Custom CSS *@
    <link rel="stylesheet" href="~/css/site.css" />

    @* Boostrap 5 *@
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    @* Bootstrap Icons *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    @* Don't remove jQuery cdn! *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
            integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    @* DataTable *@
    <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css" rel="stylesheet" />
</head>

<body>
    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <!-- Logo and Title -->
                <div class="d-flex align-items-center">
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <div class="header-logo">
                            <a class="text-decoration-none" asp-action="Index" asp-controller="Admin">

                                <img src="https://play-lh.googleusercontent.com/ZYHXbtAopfQfJjCiTdDciNQFtzw6eY0fUbBBlzsrJ7bEVZlh9qfppjt8E66ia7JyHRY0=w240-h480-rw" alt="MTB Logo">
                            </a>
                        </div>
                        <div claa="navbar-brand">
                            <a class="text-white navbar-brand text-decoration-none" asp-action="Index" asp-controller="Admin">MTB Pay Ticketing System</a>
                        </div>
                    }
                    else if (Context.Session.GetString("Role") == "User")
                    {
                        <div class="header-logo">
                            <a class="text-decoration-none" asp-action="Index" asp-controller="User">

                                <img src="https://play-lh.googleusercontent.com/ZYHXbtAopfQfJjCiTdDciNQFtzw6eY0fUbBBlzsrJ7bEVZlh9qfppjt8E66ia7JyHRY0=w240-h480-rw" alt="MTB Logo">
                            </a>
                        </div>
                        <div claa="navbar-brand">
                            <a class="text-white navbar-brand text-decoration-none" asp-action="Index" asp-controller="User">MTB Pay Ticketing System</a>
                        </div>
                    }
                    else if (Context.Session.GetString("Role") == "Supervisor")
                    {
                        <div class="header-logo">
                            <a class="text-decoration-none" asp-action="Index" asp-controller="Supervisor">

                                <img src="https://play-lh.googleusercontent.com/ZYHXbtAopfQfJjCiTdDciNQFtzw6eY0fUbBBlzsrJ7bEVZlh9qfppjt8E66ia7JyHRY0=w240-h480-rw" alt="MTB Logo">
                            </a>
                        </div>
                        <div claa="navbar-brand">
                            <a class="text-white navbar-brand text-decoration-none" asp-action="Index" asp-controller="Supervisor">MTB Pay Ticketing System</a>
                        </div>
                    }
                    else
                    {
                        <div class="header-logo">
                            <a class="text-decoration-none" asp-action="Index" asp-controller="Home">
                                <img src="https://play-lh.googleusercontent.com/ZYHXbtAopfQfJjCiTdDciNQFtzw6eY0fUbBBlzsrJ7bEVZlh9qfppjt8E66ia7JyHRY0=w240-h480-rw" alt="MTB Logo">
                            </a>
                        </div>
                        <div claa="navbar-brand">
                            <a class="text-white navbar-brand text-decoration-none" asp-action="Index" asp-controller="Home">MTB Pay Ticketing System</a>
                        </div>
                    }
                </div>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigation Links -->
                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("Role") == null)
                        {
                            <!-- Show Login if user is not logged in -->
                            <li class="nav-item">
                                <a class="nav-link m-4" href="/Login/UserLogin">
                                    Login
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-in-right" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M6 3.5a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-2a.5.5 0 0 0-1 0v2A1.5 1.5 0 0 0 6.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-8A1.5 1.5 0 0 0 5 3.5v2a.5.5 0 0 0 1 0z" />
                                        <path fill-rule="evenodd" d="M11.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H1.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z" />
                                    </svg>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="#">@Context.Session.GetString("AgentName")</a>
                            </li>

                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <!-- Show User Management link if the user is an admin -->
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/UserManagement">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
                                            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4" />
                                        </svg>
                                        User Management
                                    </a>
                                </li>
                            }
                            <!-- Show Logout if user is logged in -->
                            <li class="nav-item">
                                <a class="nav-link" href="/Login/UserLogout">
                                    Logout
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 2h8A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 5 12.5v-2a.5.5 0 0 1 1 0z" />
                                        <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708z" />
                                    </svg>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <div>
        <main role="main" class="">
            @RenderBody()
            @RenderSection("Scripts", required: false)
        </main>
    </div>

    <!-- Footer -->
    <footer class="text-center text-lg-start p-4 position-relative bottom-0 w-100">
        <div class="d-flex justify-content-center align-items-center text-center">
            <div class="m-2 copy-rights">
                © 2025 MiBS Myanmar. All Rights Reserved.
            </div>
            <div class="m-2 copy-rights">
                <a class="mx-2 text-decoration-none copy-rights" href="#">Terms & Conditions</a>
                <a class="mx-2 text-decoration-none copy-rights" href="#">Privacy Policy</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js"></script>

    @* jQuery *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
            integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    @* Bootstrap 5 *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>

    @* DataTable *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js" asp-append-version="true"></script>
</body>

</html>
