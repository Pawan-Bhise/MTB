     };

     const subSubCategoryOptions = {
         "Bank Account Cash In Transaction": [
             // "Option 1",
             // "Option 2"
         ],
         // "MPU Cash In Transaction": [
         //     "Option 3",
         //     "Option 4"
         // ]
     };

     // Populate dropdowns
     function populateDropdown(id, options) {
         const select = document.getElementById(id);
         select.innerHTML = '';
         options.forEach(option => {
             const opt = document.createElement('option');
             opt.value = option;
             opt.textContent = option;
             select.appendChild(opt);
         });
     }

     // Populate dropdowns for Type of Caller, Customer Segment, and Type of Call
     populateDropdown('typeOfCaller', typeOfCallerOptions);
     populateDropdown('customerSegment', customerSegmentOptions);
     populateDropdown('typeOfCall', Object.keys(categoryOptions));

     // Populate category dropdown
     document.getElementById('typeOfCall').addEventListener('change', function () {
         const selectedTypeOfCall = this.value;
         const categories = categoryOptions[selectedTypeOfCall] || [];
         populateDropdown('category', categories);
         document.getElementById('category').dispatchEvent(new Event('change'));
     });

     // Event listener for category to update subCategory
     document.getElementById('category').addEventListener('change', function () {
         const selectedCategory = this.value;
         const subCategories = subCategoryOptions[selectedCategory] || [];
         populateDropdown('subCategory', subCategories);
         document.getElementById('subCategory').dispatchEvent(new Event('change'));
     });

     // Event listener for subCategory to update subSubCategory
     document.getElementById('subCategory').addEventListener('change', function () {
         const selectedSubCategory = this.value;
         const subSubCategories = subSubCategoryOptions[selectedSubCategory] || [];
         populateDropdown('subSubCategory', subSubCategories);
     });

     // Populate initial dropdowns
     document.getElementById('typeOfCall').dispatchEvent(new Event('change'));

     // Run this on page load
     if ($('#openSrOption').is(':checked')) {
         $('#customerInfoSection').show();
         $('#ticketManagementSection').hide();
     }

     if ($('#raiseTicketOption').is(':checked')) {
         $('#customerInfoSection').hide();
         $('#ticketManagementSection').show();
     }
</script>