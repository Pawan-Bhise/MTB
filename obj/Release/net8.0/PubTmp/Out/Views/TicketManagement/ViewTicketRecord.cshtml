             "Merchant Fraud Transaction"
         ],
          "Disputes": [
              "Top Up Disputes Transaction (Customer)",
              "Bill Payment Disputes Transaction (YESC, MESC, ESE-NPT)",
              "Bill Payment Disputes Transaction (5BB)",
             "Top Up Disputes Transaction (Agent)",
             "Top Up Disputes Transaction (Merchant)"
         ],
         "Transaction Limit": [
             "Complaints for Transaction limit"
         ],
         "Bill Payment": [
             "YESC from Agent Wallet",
             "MESC from Agent Wallet",
             "ESE-NPT from Agent Wallet",
             "Canal+ from Agent Wallet",
             "YESC from Merchant Wallet",
             "MESC from Merchant Wallet",
             "ESE-NPT from Merchant Wallet",
             "Canal+ from Merchant Wallet"
         ],
         "Application Log In": [
             "Application login Error",
             "Firebase issues",
             "System Failure",
             "System Maintainance",
             "Unable to download the application"

         ],
         "Registration": [
             "Complain for Account register"
         ],
         "OTP":[
             "OTP receipt error ( Bank Account Cash In)",
             "OTP receipt error ( Bank Account Linkage)",
             "OTP receipt error ( Application Log In)",
             "OTP receipt error ( Account Registeration)",
             "OTP receipt error ( Forgot Pin )"
         ],
         "Cash Code (Complaint)": [
             "Complaint for Cash Code error",
         ],
         "Fund Transfer": [
             "Complaints for Fund Transfer Transaction"
         ],
         "Send Money": [
